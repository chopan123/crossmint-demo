# Crossmint client-side API key (must be a "client" key, starts with ck_)
# Create one at https://www.crossmint.com/console -> API Keys
# Staging keys (ck_staging_...) use Stellar testnet; production keys (ck_production_...) use Stellar mainnet.
NEXT_PUBLIC_CROSSMINT_API_KEY=ck_staging_replace_me

# Stellar chain identifier used by the wallet provider.
NEXT_PUBLIC_CROSSMINT_CHAIN=stellar

# Stellar network this environment targets (testnet | mainnet).
# Staging keys (ck_staging_) -> testnet; production keys (ck_production_) -> mainnet.
#
# The app always reads .env. Keep saved variable sets in .env.staging and
# .env.production (both gitignored) and switch by copying one into .env:
#   npm run env:staging   # testnet
#   npm run env:mainnet   # mainnet
NEXT_PUBLIC_STELLAR_NETWORK=testnet
